{
	"name": "ai-handoff-linter",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run build:plugin && bun run build:ui",
		"build:plugin": "vite build --config vite.plugin.config.ts",
		"build:ui": "vite build --config vite.ui.config.ts",
		"assets": "bun scripts/build-assets.ts",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:write": "biome check . --write",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@base-ui/react": "1.6.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"embla-carousel-react": "8.6.0",
		"lucide-react": "1.24.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"shadcn": "4.13.0",
		"tailwind-merge": "3.6.0",
		"tw-animate-css": "1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@figma/plugin-typings": "1.131.0",
		"@iarna/toml": "2.2.5",
		"@resvg/resvg-js": "2.6.2",
		"@tailwindcss/vite": "4.3.2",
		"@tsconfig/strictest": "2.0.8",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"lefthook": "2.1.10",
		"tailwindcss": "4.3.2",
		"typescript": "7.0.2",
		"vite": "8.1.4",
		"vitest": "4.1.10"
	}
}
