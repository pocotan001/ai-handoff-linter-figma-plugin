{
	"name": "ai-handoff-linter",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run build:plugin && bun run build:ui",
		"build:plugin": "vite build --config vite.plugin.config.ts",
		"build:ui": "vite build --config vite.ui.config.ts",
		"assets": "bun scripts/build-assets.ts",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "1.6.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"embla-carousel-react": "8.6.0",
		"lucide-react": "1.21.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"shadcn": "4.11.0",
		"tailwind-merge": "3.6.0",
		"tw-animate-css": "1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@figma/plugin-typings": "1.117.0",
		"@resvg/resvg-js": "2.6.2",
		"@tailwindcss/vite": "4.3.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"tailwindcss": "4.3.2",
		"typescript": "5.8.3",
		"vite": "8.0.16",
		"vitest": "4.1.9"
	}
}
