{
	"extends": "@tsconfig/strictest/tsconfig.json",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"skipLibCheck": true,
		"types": ["@figma/plugin-typings", "vitest/globals"],
		"noEmit": true,
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src", "vitest.config.ts"]
}
